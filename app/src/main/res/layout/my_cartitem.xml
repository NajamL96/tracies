<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    app:cardCornerRadius="@dimen/_12sdp"
    android:layout_margin="@dimen/_10sdp">

    <LinearLayout
        android:id="@+id/cart_item"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_70sdp"
        android:clickable="true"
        >

        <ImageView
            android:id="@+id/shoe"
            android:layout_width="@dimen/_70sdp"
            android:layout_height="@dimen/_70sdp"
            android:src="@drawable/shoe"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            >

            <TextView
                android:id="@+id/cart_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/_10sdp"
                android:layout_marginTop="@dimen/_5sdp"
                android:text="Adidas Shoes"
                android:textAlignment="center"
                android:textColor="@color/pink"
                android:textSize="@dimen/_9sdp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cart_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/_10sdp"
                android:text="$300"
                android:layout_below="@+id/cart_title"
                android:textAlignment="center"
                android:textSize="@dimen/_9sdp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cart_quantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/cart_price"
                android:layout_marginLeft="@dimen/_10sdp"
                android:text="Quantity"
                android:textAlignment="center"
                android:textColor="@color/pink"
                android:textSize="@dimen/_9sdp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/decrease_btn"
                android:layout_width="@dimen/_12sdp"
                android:layout_height="@dimen/_20sdp"
                android:layout_below="@id/cart_quantity"
                android:layout_marginLeft="@dimen/_10sdp"
                android:src="@drawable/minus" />

<!--            <ImageView-->
<!--                android:id="@+id/decrease_btn_pink"-->
<!--                android:layout_width="@dimen/_10sdp"-->
<!--                android:layout_height="@dimen/_20sdp"-->
<!--                android:layout_below="@id/cart_quantity"-->
<!--                android:layout_marginLeft="@dimen/_10sdp"-->
<!--                android:src="@drawable/minus" />-->

            <TextView
                android:id="@+id/edit_quantity"
                android:layout_width="@dimen/_30sdp"
                android:layout_height="@dimen/_17sdp"
                android:layout_below="@id/cart_quantity"
                android:layout_alignLeft="@id/decrease_btn"
                android:layout_marginLeft="@dimen/_10sdp"
                android:layout_marginRight="@dimen/_10sdp"
                android:gravity="center"
                android:inputType="number"
                android:text="1"
                android:textSize="@dimen/_9sdp" />


            <ImageView
                android:id="@+id/increase_btn"
                android:layout_width="@dimen/_12sdp"
                android:layout_height="@dimen/_20sdp"
                android:layout_below="@id/cart_quantity"
                android:layout_marginLeft="@dimen/_50sdp"
                android:src="@drawable/plus" />

            <TextView
                android:id="@+id/sizeItem"
                android:layout_width="@dimen/_10sdp"
                android:layout_height="@dimen/_20sdp"
                android:layout_below="@id/cart_quantity"
                android:layout_marginLeft="@dimen/_100sdp"
                android:gravity="center"
                android:text="L"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="@dimen/_25sdp"
                android:layout_marginLeft="@dimen/_95sdp"
                android:layout_marginTop="@dimen/_23sdp"
                android:gravity="center"
                android:src="@drawable/plus"
                android:text="size"
                android:textColor="@color/pink"
                android:textStyle="bold" />


            <ImageView
                android:id="@+id/greenTick"
                android:layout_width="@dimen/_15sdp"
                android:layout_height="@dimen/_15sdp"
                android:layout_marginLeft="@dimen/_170sdp"
                android:layout_marginTop="@dimen/_8sdp"
                android:background="@drawable/ppink_tick"

               />

            <ImageView
                android:id="@+id/greyTick"
                android:layout_width="@dimen/_15sdp"
                android:layout_height="@dimen/_15sdp"
                android:layout_marginLeft="@dimen/_170sdp"
                android:layout_marginTop="@dimen/_8sdp"
                android:background="@drawable/grey"
                android:textAlignment="center"
                android:textColor="@color/pink"
                android:textSize="@dimen/_13sdp"
                android:textStyle="bold" />


            <ImageView
                android:id="@+id/del"
                android:layout_width="@dimen/_16sdp"
                android:layout_height="@dimen/_18sdp"
                android:layout_marginLeft="@dimen/_170sdp"
                android:layout_marginTop="@dimen/_50sdp"
                android:background="@drawable/delete"
                android:textAlignment="center"
                android:textColor="@color/pink"
                android:textSize="@dimen/_13sdp"
                android:textStyle="bold" />


        </RelativeLayout>

    </LinearLayout>








</androidx.cardview.widget.CardView>